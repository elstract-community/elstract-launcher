/*
 * Elstract Launcher — Services/LibraryService.cs
 * Manages the full game library: persistence, launch, playtime tracking
 */
using System.Collections.ObjectModel;
using System.Diagnostics;
using System.IO;
using System.Windows;
using ElstractLauncher.Models;
using Newtonsoft.Json;

namespace ElstractLauncher.Services;

public class LibraryService
{
    private readonly SettingsService _settings;
    private readonly string _libPath;
    private readonly Dictionary<Guid, (Process Proc, DateTime Start)> _sessions = new();
    private readonly System.Timers.Timer _autoSaveTimer;

    public ObservableCollection<Game> Games { get; } = new();

    public LibraryService(SettingsService settings)
    {
        _settings = settings;
        _libPath = Path.Combine(
            Environment.GetFolderPath(Environment.SpecialFolder.ApplicationData),
            "Elstract", "library.json");

        // Auto-save every 30 seconds to keep data fresh
        _autoSaveTimer = new System.Timers.Timer(30_000);
        _autoSaveTimer.Elapsed += (_, _) => SaveAll();
        _autoSaveTimer.AutoReset = true;
        _autoSaveTimer.Start();
    }

    public void Load()
    {
        try
        {
            if (!File.Exists(_libPath)) return;
            var json  = File.ReadAllText(_libPath);
            var games = JsonConvert.DeserializeObject<List<Game>>(json) ?? new();
            Games.Clear();
            foreach (var g in games) Games.Add(g);
        }
        catch (Exception ex) { Debug.WriteLine($"[LibraryService] Load error: {ex.Message}"); }
    }

    public void SaveAll()
    {
        try
        {
            Directory.CreateDirectory(Path.GetDirectoryName(_libPath)!);
            File.WriteAllText(_libPath, JsonConvert.SerializeObject(Games, Formatting.Indented));
        }
        catch (Exception ex) { Debug.WriteLine($"[LibraryService] Save error: {ex.Message}"); }
    }

    public void AddGame(Game game) { Games.Add(game); SaveAll(); }
    public void RemoveGame(Game game) { Games.Remove(game); SaveAll(); }
    public void UpdateGame(Game game) { SaveAll(); }

    public async Task LaunchGameAsync(Game game)
    {
        if (!game.IsExeLinked)
            throw new InvalidOperationException("No executable linked to this game.");
        if (game.IsRunning) return;

        var process = new Process
        {
            StartInfo = new ProcessStartInfo
            {
                FileName         = game.ExePath,
                WorkingDirectory = Path.GetDirectoryName(game.ExePath),
                UseShellExecute  = true
            },
            EnableRaisingEvents = true
        };

        process.Start();
        var startTime = DateTime.UtcNow;
        _sessions[game.Id] = (process, startTime);
        game.IsRunning  = true;
        game.LastPlayed = DateTime.Now;
        game.LaunchCount++;

        App.Discord.SetGamePresence(game);

        if (_settings.Current.MinimizeOnLaunch)
        {
            Application.Current.Dispatcher.Invoke(() =>
                Application.Current.MainWindow.WindowState = WindowState.Minimized);
        }

        await Task.Run(() => { try { process.WaitForExit(); } catch { } });
        OnGameExited(game, startTime);
    }

    private void OnGameExited(Game game, DateTime sessionStart)
    {
        game.TotalPlayTime += DateTime.UtcNow - sessionStart;
        game.IsRunning = false;
        _sessions.Remove(game.Id);
        App.Discord.SetIdlePresence();
        SaveAll();

        if (_settings.Current.CloseOnGameExit)
        {
            Application.Current.Dispatcher.Invoke(() => Application.Current.Shutdown());
        }
        else
        {
            Application.Current.Dispatcher.Invoke(() =>
            {
                if (Application.Current.MainWindow.WindowState == WindowState.Minimized)
                    Application.Current.MainWindow.WindowState = WindowState.Normal;
            });
        }
    }
}
