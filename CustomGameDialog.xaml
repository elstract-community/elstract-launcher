<!--
  Elstract Launcher — Views/SettingsToggleRow.xaml
  Label + description + custom pink toggle switch (click handled in code-behind)
-->
<UserControl x:Class="ElstractLauncher.Views.SettingsToggleRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="0,0,0,12">
  <Border Background="{StaticResource BgCardBrush}"
          BorderBrush="{StaticResource BorderSubtleBrush}"
          BorderThickness="1" CornerRadius="10"
          Padding="16,12">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="16"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0">
        <TextBlock x:Name="LabelText"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   FontSize="13" FontWeight="SemiBold"/>
        <TextBlock x:Name="DescText"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontSize="12" Margin="0,3,0,0"
                   TextWrapping="Wrap"/>
      </StackPanel>

      <!-- Custom toggle — click handled in code-behind, no command binding -->
      <Border x:Name="ToggleBorder"
              Grid.Column="2"
              Width="44" Height="24"
              CornerRadius="12"
              Cursor="Hand"
              Background="{StaticResource BorderSubtleBrush}"
              VerticalAlignment="Center"
              MouseLeftButtonDown="ToggleBorder_Click">
        <Ellipse x:Name="ToggleKnob"
                 Width="18" Height="18"
                 Fill="White"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Left"
                 Margin="3,0,0,0">
          <Ellipse.Effect>
            <DropShadowEffect Color="#000" BlurRadius="4" ShadowDepth="1" Opacity="0.4"/>
          </Ellipse.Effect>
        </Ellipse>
      </Border>
    </Grid>
  </Border>
</UserControl>
