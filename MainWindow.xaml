/*
 * Elstract Launcher — Views/MainWindow.xaml.cs
 * Code-behind: custom chrome, window controls.
 *
 * DataContext назначается здесь после того, как App.OnStartup
 * уже инициализировал все сервисы (Library, Settings, Discord).
 */
using System.Windows;
using System.Windows.Input;
using ElstractLauncher.ViewModels;

namespace ElstractLauncher.Views;

public partial class MainWindow : Window
{
    public MainWindow()
    {
        InitializeComponent();

        // Назначаем DataContext только здесь — к этому моменту
        // App.OnStartup уже отработал и все сервисы готовы.
        DataContext = new MainWindowViewModel();
    }

    // ── Window chrome controls ─────────────────────────────────────

    private void TitleBar_MouseLeftButtonDown(object sender, MouseButtonEventArgs e)
    {
        if (e.ClickCount == 2)
            ToggleMaximize();
        else
            DragMove();
    }

    private void MinimizeButton_Click(object sender, RoutedEventArgs e)
        => WindowState = WindowState.Minimized;

    private void MaximizeButton_Click(object sender, RoutedEventArgs e)
        => ToggleMaximize();

    private void CloseButton_Click(object sender, RoutedEventArgs e)
        => Close();

    private void ToggleMaximize()
    {
        WindowState = WindowState == WindowState.Maximized
            ? WindowState.Normal
            : WindowState.Maximized;

        MaxIcon.Text = WindowState == WindowState.Maximized ? "❐" : "□";
    }
}
