/*
 * Elstract Launcher — Views/CustomGameDialog.xaml.cs
 * Full custom game editor: name, description, icon, background, developer, genre.
 */
using System.IO;
using System.Windows;
using System.Windows.Input;
using System.Windows.Media.Imaging;
using Microsoft.Win32;

namespace ElstractLauncher.Views;

public partial class CustomGameDialog : Window
{
    public string GameName       { get; private set; } = string.Empty;
    public string GameDesc       { get; private set; } = string.Empty;
    public string GameDeveloper  { get; private set; } = string.Empty;
    public string GameGenre      { get; private set; } = string.Empty;
    public string? IconPath      { get; private set; }
    public string? BackgroundPath{ get; private set; }

    public CustomGameDialog()
    {
        InitializeComponent();
        Loaded += (_, _) => { NameInput.Focus(); };
        MouseLeftButtonDown += (_, _) => DragMove();
        NameInput.KeyDown += (_, e) =>
        {
            if (e.Key == Key.Escape) Cancel_Click(this, new RoutedEventArgs());
        };
    }

    // ── Image pickers ──────────────────────────────────────────────────

    private void PickIcon_Click(object sender, MouseButtonEventArgs e)
    {
        var path = PickImage("Select Icon / Cover Image");
        if (path is null) return;
        IconPath = path;
        IconImg.Source = LoadImage(path);
        IconPlaceholder.Visibility = Visibility.Collapsed;
    }

    private void PickBackground_Click(object sender, MouseButtonEventArgs e)
    {
        var path = PickImage("Select Background / Banner");
        if (path is null) return;
        BackgroundPath = path;
        BgImg.Source = LoadImage(path);
        BgPlaceholder.Visibility = Visibility.Collapsed;
    }

    private static string? PickImage(string title)
    {
        var dlg = new OpenFileDialog
        {
            Title  = title,
            Filter = "Images (*.png;*.jpg;*.jpeg;*.bmp;*.webp)|*.png;*.jpg;*.jpeg;*.bmp;*.webp|All files|*.*"
        };
        return dlg.ShowDialog() == true ? dlg.FileName : null;
    }

    private static BitmapImage? LoadImage(string path)
    {
        try
        {
            var bmp = new BitmapImage();
            bmp.BeginInit();
            bmp.UriSource        = new Uri(path, UriKind.Absolute);
            bmp.CacheOption      = BitmapCacheOption.OnLoad;
            bmp.DecodePixelWidth = 400;
            bmp.EndInit();
            return bmp;
        }
        catch { return null; }
    }

    // ── Dialog result ──────────────────────────────────────────────────

    private void Add_Click(object sender, RoutedEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(NameInput.Text))
        {
            NameInput.BorderBrush = new System.Windows.Media.SolidColorBrush(
                System.Windows.Media.Color.FromRgb(0xFF, 0x47, 0x57));
            NameInput.Focus();
            return;
        }
        GameName      = NameInput.Text.Trim();
        GameDesc      = DescInput.Text.Trim();
        GameDeveloper = DevInput.Text.Trim();
        GameGenre     = GenreInput.Text.Trim();
        DialogResult  = true;
    }

    private void Cancel_Click(object sender, RoutedEventArgs e)
        => DialogResult = false;
}
