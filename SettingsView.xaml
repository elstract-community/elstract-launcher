/*
 * Elstract Launcher — Views/SettingsToggleRow.xaml.cs
 * Custom toggle row — IsOn handled in code-behind to avoid binding errors.
 */
using System.Windows;
using System.Windows.Controls;
using System.Windows.Media;

namespace ElstractLauncher.Views;

public partial class SettingsToggleRow : UserControl
{
    // ── Dependency Properties ─────────────────────────────────────

    public static readonly DependencyProperty LabelProperty =
        DependencyProperty.Register(nameof(Label), typeof(string), typeof(SettingsToggleRow),
            new PropertyMetadata(string.Empty, (d, e) =>
                ((SettingsToggleRow)d).LabelText.Text = (string)e.NewValue));

    public static readonly DependencyProperty DescProperty =
        DependencyProperty.Register(nameof(Desc), typeof(string), typeof(SettingsToggleRow),
            new PropertyMetadata(string.Empty, (d, e) =>
                ((SettingsToggleRow)d).DescText.Text = (string)e.NewValue));

    public static readonly DependencyProperty IsOnProperty =
        DependencyProperty.Register(nameof(IsOn), typeof(bool), typeof(SettingsToggleRow),
            new FrameworkPropertyMetadata(false,
                FrameworkPropertyMetadataOptions.BindsTwoWayByDefault,
                OnIsOnChanged));

    private static void OnIsOnChanged(DependencyObject d, DependencyPropertyChangedEventArgs e)
        => ((SettingsToggleRow)d).UpdateVisual((bool)e.NewValue);

    public string Label { get => (string)GetValue(LabelProperty);  set => SetValue(LabelProperty, value); }
    public string Desc  { get => (string)GetValue(DescProperty);   set => SetValue(DescProperty, value); }
    public bool   IsOn  { get => (bool)GetValue(IsOnProperty);     set => SetValue(IsOnProperty, value); }

    // ── Pink / off colors ─────────────────────────────────────────
    private static readonly SolidColorBrush _onBrush  = new(Color.FromRgb(0xFF, 0x1A, 0x7A));
    private static readonly SolidColorBrush _offBrush = new(Color.FromRgb(0x2D, 0x20, 0x40));

    public SettingsToggleRow()
    {
        InitializeComponent();
    }

    // ── Click handler ─────────────────────────────────────────────

    private void ToggleBorder_Click(object sender, System.Windows.Input.MouseButtonEventArgs e)
    {
        IsOn = !IsOn;
        e.Handled = true;
    }

    // ── Visual update ─────────────────────────────────────────────

    private void UpdateVisual(bool isOn)
    {
        if (ToggleBorder == null || ToggleKnob == null) return;

        ToggleBorder.Background       = isOn ? _onBrush : _offBrush;
        ToggleKnob.HorizontalAlignment = isOn ? HorizontalAlignment.Right : HorizontalAlignment.Left;
        ToggleKnob.Margin             = isOn ? new Thickness(0, 0, 3, 0) : new Thickness(3, 0, 0, 0);
    }
}
